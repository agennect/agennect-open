# Server
PORT=3000
HOST=0.0.0.0
REGISTRY_NAME="My Agent Registry"
REGISTRY_URL=http://localhost:3000

# Database
DB_PATH=./data/registry.db

# LLM Provider for embeddings and eval
# Options: anthropic | openai | ollama
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_URL=http://localhost:11434

# Embedding model
# anthropic: voyage-3 (via Anthropic API)
# openai: text-embedding-3-small
# ollama: nomic-embed-text
EMBEDDING_MODEL=voyage-3

# Embedding dimensions (must match the model)
# voyage-3: 1024, text-embedding-3-small: 1536, nomic-embed-text: 768
EMBEDDING_DIMS=1024

# Admin (bootstrap token)
# On first boot this value becomes an admin-scoped token in the tokens table
# (name = "env-bootstrap"). Subsequent tokens are managed via POST /admin/tokens.
ADMIN_TOKEN=change-me-before-deploy

# CORS allowlist: comma-separated origins, or "*" for any.
# Default "*" is convenient for local dev, NOT for production.
CORS_ORIGINS=*

# Health check interval in ms (default: 5 minutes)
HEALTH_CHECK_INTERVAL=300000
